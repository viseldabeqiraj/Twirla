# SQLite (local dev — relative to Twirla.Api working directory)
DATABASE_URL=Data Source=twirla.db

# Twirla API (.NET) — same value in appsettings:
# ConnectionStrings__Database=Data Source=twirla.db

# Azure Production (appsettings.Production.json default):
# ConnectionStrings__Database=Data Source=/home/twirla.db

# Skip migrations on startup (tests only):
# TWIRLA_SKIP_DB_BOOTSTRAP=1

# Private shop import file (gitignored): backend/Twirla.Api/Data/shops.json
