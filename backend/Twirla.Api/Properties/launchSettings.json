{
  "profiles": {
    "http": {
      "commandName": "Project",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "TWIRLA_CAMPAIGN_SETUP_ACCESS_CODE": "local-dev-campaign-code-change-me"
      },
      "dotnetRunMessages": true,
      "applicationUrl": "http://localhost:5050"
